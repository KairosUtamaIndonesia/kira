{
  "name": "kira-v3",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "check": "bun run check:rust && bun run build",
    "check:rust": "cd src-tauri && cargo check",
    "dev": "vite",
    "devtools": "react-devtools",
    "format": "oxfmt .",
    "format:all": "bun run format && bun run format:rust",
    "format:all:check": "bun run format:check && bun run format:rust:check",
    "format:check": "oxfmt --check .",
    "format:rust": "cd src-tauri && cargo fmt",
    "format:rust:check": "cd src-tauri && cargo fmt --check",
    "lint": "oxlint",
    "lint:all": "bun run lint && bun run lint:rust",
    "lint:fix": "oxlint --fix",
    "lint:rust": "cd src-tauri && cargo clippy --all-targets --all-features -- -D warnings",
    "preview": "vite preview",
    "tauri": "bun scripts/tauri.ts",
    "test:rust": "cd src-tauri && cargo test"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dockview-react": "^6.6.1",
    "lucide-react": "^1.17.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-resizable-panels": "^4.11.2",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "react-devtools": "^7.0.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
