{
  "extends": "@kira/tsconfig/react.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "node"],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["vite-env.d.ts", "routeTree.gen.ts", "**/*.ts", "**/*.tsx", "**/*.mts"],
  "exclude": ["node_modules", ".output", ".nitro"]
}
