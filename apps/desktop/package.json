{
  "name": "@kira/desktop",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsgo && vite build",
    "check": "bun run check:rust && bun run build",
    "check:rust": "cd src-tauri && cargo check",
    "dev": "vite",
    "devtools": "react-devtools",
    "format": "oxfmt .",
    "format:all": "bun run format && bun run format:rust",
    "format:all:check": "bun run format:check && bun run format:rust:check",
    "format:check": "oxfmt --check .",
    "format:rust": "cd src-tauri && cargo fmt",
    "format:rust:check": "cd src-tauri && cargo fmt --check",
    "lint": "oxlint",
    "lint:all": "bun run lint && bun run lint:rust",
    "lint:fix": "oxlint --fix",
    "lint:rust": "cd src-tauri && cargo clippy --all-targets --all-features -- -D warnings",
    "preview": "vite preview",
    "tauri": "bun scripts/tauri.ts",
    "tauri:dev": "bun scripts/tauri.ts dev",
    "test:rust": "cd src-tauri && cargo test"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@monaco-editor/react": "^4.7.0",
    "@pierre/trees": "^1.0.0-beta.4",
    "@shikijs/monaco": "^4.2.0",
    "@strands-agents/sdk": "^1.6.0",
    "@streamdown/code": "^1.1.1",
    "@streamdown/mermaid": "^1.0.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-virtual": "^3.14.3",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dockview-react": "^6.6.1",
    "lucide-react": "^1.21.0",
    "monaco-editor": "^0.55.1",
    "openai": "^6.43.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-resizable-panels": "^4.11.2",
    "shadcn": "^4.10.0",
    "shiki": "^4.2.0",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.6",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@kira/tsconfig": "workspace:*",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.2",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "react-devtools": "^7.0.1",
    "typescript": "~5.8.3",
    "vite": "^8.0.16"
  }
}
