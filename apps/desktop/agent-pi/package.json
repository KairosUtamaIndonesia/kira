{
  "name": "@kira/agent-pi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun build src/server.ts --target=bun --outdir=dist --entry-naming=server.mjs",
    "check": "tsc --noEmit",
    "compile": "bun build src/server.ts --compile --outfile=dist/kira-agent-pi && bun run scripts/copy-binary-assets.ts",
    "dev": "bun --watch run src/server.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint",
    "start": "bun dist/server.mjs",
    "test": "bun test"
  },
  "dependencies": {
    "@aliou/sh": "^0.2.0",
    "@earendil-works/pi-agent-core": "^0.75.3",
    "@earendil-works/pi-ai": "^0.75.3",
    "@earendil-works/pi-coding-agent": "^0.75.3",
    "@earendil-works/pi-tui": "^0.79.1",
    "@hono/node-server": "^2.0.3",
    "better-sqlite3": "^12.10.0",
    "hono": "^4.8.3",
    "typebox": "^1.1.24",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@kira/tsconfig": "workspace:*",
    "@types/bun": "^1.3.3",
    "@types/ws": "^8.5.13",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "typescript": "^6.0.3"
  }
}
