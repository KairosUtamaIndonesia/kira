{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kira",
  "version": "3.1.0",
  "identifier": "com.kairos.kira",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd agent-pi && bun run build && bun run scripts/copy-sdk-assets.ts && cd .. && bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kira",
        "width": 800,
        "height": 600,
        "decorations": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "app", "deb", "appimage", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "macOS": {
      "signingIdentity": "-"
    },
    "resources": {
      "../agent-pi/dist/server.mjs": "agent-runtime/server.mjs",
      "../agent-pi/dist/pi-sdk": "agent-runtime/pi-sdk",
      "../agent-pi/skills": "agent-runtime/skills"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/KairosUtamaIndonesia/kira/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgzQUFFRkU3MkNFMzk2MTcKUldRWGx1TXM1KytxZzZTRm9pUlVvVzU1QWxjVVR1RDZkWHJESzhmVlpFeE5NTGZoTG5DeDkvUVEK"
    }
  }
}
