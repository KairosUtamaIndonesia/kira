        "format:check": "oxfmt --check .",
        "lint": "oxlint"
    },
    "dependencies": {
        "@earendil-works/pi-coding-agent": "^0.75.3"
    },
    "devDependencies": {
        "@kira/tsconfig": "workspace:*",
        "@types/bun": "^1.3.3",
        "oxfmt": "^0.53.0",
        "oxlint": "^1.68.0",
        "typescript": "^6.0.3"
    }
}
